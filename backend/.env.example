# =============================================
# KONI Backend - Konfigurasi Environment
# =============================================
# Salin file ini menjadi .env dan isi sesuai kebutuhan

# JWT Secret (ganti dengan string random yang kuat)
JWT_SECRET=ganti-dengan-string-random-minimal-32-karakter
JWT_REFRESH_SECRET=ganti-dengan-string-random-berbeda-dari-jwt-secret
JWT_EXPIRY=1h
JWT_REFRESH_EXPIRY=7d

# Email (Gmail) - untuk verifikasi email & reset password
# Cara buat App Password: Google Account > Security > 2-Step Verification > App passwords
EMAIL_USER=email-gmail-anda@gmail.com
EMAIL_PASSWORD=xxxx-xxxx-xxxx-xxxx

# URL Frontend
FRONTEND_URL=http://localhost:5173

# Database PostgreSQL
# Format: postgresql://USER:PASSWORD@HOST:PORT/NAMA_DATABASE
DATABASE_URL=postgresql://postgres:password_postgres_anda@localhost:5432/koni_db
